# Public HTTPS URL for this bridge. OIDC redirect URIs require HTTPS.
PUBLIC_BASE_URL=https://bridge.example.com

# Public HTTPS issuer URL for Pocket ID, Authelia, or another OIDC provider.
OIDC_PROVIDER_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=omada-saml-oidc
OIDC_CLIENT_SECRET=change-me

# Public HTTPS URL users open for Omada.
OMADA_PUBLIC_BASE_URL=https://omada.example.com

# Private Omada controller upstreams reachable from the bridge container.
# Use internal IPs or DNS names with ports. Do not use OMADA_PUBLIC_BASE_URL here.
OMADA_UPSTREAM_BASES=https://controller-1.internal:443,https://controller-2.internal:443

# Values from the Omada SAML settings page.
OMADA_ID=replace-with-omada-id
OMADA_RESOURCE_ID=replace-with-resource-id

# Optional. If omitted, the bridge derives one entity ID per upstream from
# OMADA_UPSTREAM_BASES plus OMADA_ID.
# OMADA_SP_ENTITY_IDS=https://controller-1.internal:443/replace-with-omada-id,https://controller-2.internal:443/replace-with-omada-id

# Optional. Generated on first run and persisted under /data when omitted.
# SATOSA_STATE_ENCRYPTION_KEY=

# Optional defaults.
# OIDC_BACKEND_NAME=oidc
# OIDC_SCOPES=openid profile email groups
# OMADA_ACS_PATH=/sso/saml/login
# OMADA_USERGROUP_TEMPLATE=admin
# PUBLIC_PORT=8080
